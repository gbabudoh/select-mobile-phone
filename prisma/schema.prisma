// Select Mobile Phone — Full Marketplace Schema
// Supports: Wholesalers, Retailers, Network Providers, Buyers, Individual Sellers
// Features: Normal Orders, Preorders, AI Chatbot, eSIM, Escrow, Trade-ins, TCO

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  INDIVIDUAL_SELLER
  RETAILER
  WHOLESALER
  NETWORK_PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ProductCondition {
  NEW
  CERTIFIED_PRE_OWNED
  REFURBISHED
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
}

enum ProductCategory {
  HANDSET
  ACCESSORY
  SIM_CARD
  ESIM_PLAN
  BUNDLE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  RESERVED
  EXPIRED
  REMOVED
}

enum OrderType {
  NORMAL
  PREORDER
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_HELD // Escrow: funds captured
  PROCESSING
  DIAGNOSTIC_CHECK // 50-point verification in progress
  SHIPPED
  DELIVERED
  BUYER_CONFIRMED // Buyer confirmed IMEI + SIM activation
  COMPLETED // Escrow released to seller
  DISPUTED
  REFUNDED
  CANCELLED
}

enum PreorderStatus {
  QUEUE_OPEN
  DEPOSIT_PAID
  ALLOCATED
  READY_TO_SHIP
  CONVERTED_TO_ORDER
  CANCELLED
}

enum EscrowStatus {
  HOLDING
  RELEASED_TO_SELLER
  REFUNDED_TO_BUYER
  DISPUTED
}

enum TradeInStatus {
  QUOTE_GIVEN
  LOCKED_IN
  DEVICE_RECEIVED
  INSPECTING
  APPROVED
  REJECTED
  CREDIT_APPLIED
}

enum EsimProvisioningStatus {
  PENDING
  ACTIVATING
  ACTIVE
  FAILED
  DEACTIVATED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum PlanType {
  PREPAID
  POSTPAID
  BYOP
  CONTRACT
  CROSS_BORDER
}

enum DiagnosticResult {
  PASS
  FAIL
  PARTIAL
}

enum Country {
  US
  CA
}

enum KycDocumentType {
  PASSPORT
  SSN
  BUSINESS_INCORPORATION
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_RELEASE
  CLOSED
}

enum DisputeReason {
  ITEM_NOT_RECEIVED
  NOT_AS_DESCRIBED
  ACTIVATION_FAILED
  OTHER
}

// ─── USERS & PROFILES ──────────────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  name          String?
  phone         String?
  avatarUrl     String?
  role          UserRole      @default(BUYER)
  status        AccountStatus @default(PENDING_VERIFICATION)
  country       Country       @default(US)
  emailVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Profile extensions (one-to-one, role-specific)
  wholesalerProfile      WholesalerProfile?
  retailerProfile        RetailerProfile?
  networkProviderProfile NetworkProviderProfile?
  sellerProfile          IndividualSellerProfile?
  buyerProfile           BuyerProfile?

  // Relations
  listings        Listing[]
  ordersAsBuyer   Order[]        @relation("BuyerOrders")
  ordersAsSeller  Order[]        @relation("SellerOrders")
  preorders       Preorder[]
  tradeIns        TradeIn[]
  chatSessions    ChatSession[]
  reviews         Review[]       @relation("ReviewAuthor")
  reviewsReceived Review[]       @relation("ReviewTarget")
  notifications   Notification[]
  addresses       Address[]
  escrowsAsBuyer  Escrow[]       @relation("EscrowBuyer")
  escrowsAsSeller Escrow[]       @relation("EscrowSeller")

  kycDocuments      KycDocument[]
  raisedDisputes    Dispute[]        @relation("DisputeRaiser")
  defendingDisputes Dispute[]        @relation("DisputeDefender")
  disputeMessages   DisputeMessage[]
  deletionRequests  DeletionRequest[]

  @@index([role])
  @@index([status])
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String? // "Home", "Warehouse", "Store"
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    Country  @default(US)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  orders Order[]

  @@index([userId])
}

// ─── ROLE-SPECIFIC PROFILES ─────────────────────────────────────────────────

model WholesalerProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName      String
  businessLicense   String?
  taxId             String?
  warehouseAddress  String?
  verification      VerificationStatus @default(UNVERIFIED)
  bulkDiscountTiers Json? // e.g. [{ minQty: 10, discountPct: 5 }, ...]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  inventoryItems InventoryItem[]
}

model RetailerProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName       String
  storeUrl        String?
  businessLicense String?
  taxId           String?
  verification    VerificationStatus @default(UNVERIFIED)
  preferredRegion Country            @default(US)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model NetworkProviderProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  carrierName     String
  carrierType     String // MVNO, MNO, Flanker
  coverageRegions Json? // ["US", "CA"] or detailed coverage map
  verification    VerificationStatus @default(UNVERIFIED)
  bountyFeePct    Float              @default(0) // Recurring bounty fee percentage
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  plans    NetworkPlan[]
  esimPool EsimInventory[]
}

model IndividualSellerProfile {
  id           String             @id @default(uuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  bio          String?
  verification VerificationStatus @default(UNVERIFIED)
  rating       Float              @default(0)
  totalSales   Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model BuyerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredCarrier String?
  preferredCountry Country  @default(US)
  savedSearches    Json? // Saved filter presets
  wishlist         Json? // Array of product IDs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── PRODUCTS & LISTINGS ────────────────────────────────────────────────────

model Product {
  id          String          @id @default(uuid())
  brand       String // Apple, Samsung, Google, etc.
  model       String // "iPhone 18 Pro", "Galaxy S26 Ultra"
  category    ProductCategory
  specs       Json? // { ram, storage, color, screenSize, dualEsim, 5g, ... }
  imageUrls   Json? // Array of image URLs
  releaseDate DateTime?
  msrp        Float? // Manufacturer suggested retail price
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  listings          Listing[]
  preorderCampaigns PreorderCampaign[]
  tradeIns          TradeIn[]

  @@unique([brand, model])
  @@index([brand])
  @@index([category])
}

model Listing {
  id               String            @id @default(uuid())
  sellerId         String
  seller           User              @relation(fields: [sellerId], references: [id])
  productId        String
  product          Product           @relation(fields: [productId], references: [id])
  title            String
  description      String?
  price            Float
  currency         String            @default("USD")
  condition        ProductCondition
  quantity         Int               @default(1)
  status           ListingStatus     @default(DRAFT)
  imei             String? // For individual device verification
  isSelectVerified Boolean           @default(false)
  diagnosticReport DiagnosticReport?
  country          Country           @default(US)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  orderItems OrderItem[]

  @@index([sellerId])
  @@index([productId])
  @@index([status])
  @@index([condition])
  @@index([country])
}

// 50-point remote diagnostic check for Select-Verified listings
model DiagnosticReport {
  id        String           @id @default(uuid())
  listingId String           @unique
  listing   Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  result    DiagnosticResult
  score     Int // 0-50 points
  details   Json // { battery: "PASS", screen: "PASS", ... }
  checkedAt DateTime         @default(now())
}

// ─── WHOLESALER INVENTORY (B2B) ─────────────────────────────────────────────

model InventoryItem {
  id                  String            @id @default(uuid())
  wholesalerProfileId String
  wholesalerProfile   WholesalerProfile @relation(fields: [wholesalerProfileId], references: [id], onDelete: Cascade)
  productId           String
  sku                 String?
  quantityAvailable   Int
  quantityReserved    Int               @default(0)
  unitCost            Float
  bulkPrice           Float? // Discounted price for bulk
  minOrderQty         Int               @default(1)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([wholesalerProfileId])
  @@index([productId])
}

// ─── NETWORK PLANS & eSIM ───────────────────────────────────────────────────

model NetworkPlan {
  id                       String                 @id @default(uuid())
  networkProviderProfileId String
  networkProviderProfile   NetworkProviderProfile @relation(fields: [networkProviderProfileId], references: [id], onDelete: Cascade)
  name                     String // "Unlimited Cross-Border", "5GB Prepaid"
  planType                 PlanType
  monthlyPrice             Float
  dataLimitGB              Float? // null = unlimited
  talkMinutes              Int? // null = unlimited
  textMessages             Int? // null = unlimited
  contractMonths           Int? // null = no contract (prepaid/BYOP)
  coverageCountries        Json // ["US"], ["US","CA"], etc.
  features                 Json? // { hotspot: true, roaming: true, ... }
  isActive                 Boolean                @default(true)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  esimProvisionings EsimProvisioning[]
  orderItems        OrderItem[]

  @@index([networkProviderProfileId])
  @@index([planType])
}

model EsimInventory {
  id                       String                 @id @default(uuid())
  networkProviderProfileId String
  networkProviderProfile   NetworkProviderProfile @relation(fields: [networkProviderProfileId], references: [id], onDelete: Cascade)
  activationCode           String                 @unique
  iccid                    String                 @unique
  isAssigned               Boolean                @default(false)
  createdAt                DateTime               @default(now())

  provisioning EsimProvisioning?

  @@index([networkProviderProfileId])
  @@index([isAssigned])
}

model EsimProvisioning {
  id              String                 @id @default(uuid())
  orderId         String
  order           Order                  @relation(fields: [orderId], references: [id])
  esimInventoryId String?                @unique
  esimInventory   EsimInventory?         @relation(fields: [esimInventoryId], references: [id])
  networkPlanId   String
  networkPlan     NetworkPlan            @relation(fields: [networkPlanId], references: [id])
  status          EsimProvisioningStatus @default(PENDING)
  activatedAt     DateTime?
  deactivatedAt   DateTime?
  createdAt       DateTime               @default(now())

  @@index([orderId])
}

// ─── ORDERS (Normal + Preorder) ─────────────────────────────────────────────

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique @default(uuid())
  buyerId           String
  buyer             User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId          String
  seller            User        @relation("SellerOrders", fields: [sellerId], references: [id])
  orderType         OrderType
  status            OrderStatus @default(PENDING_PAYMENT)
  subtotal          Float
  tax               Float       @default(0)
  shippingCost      Float       @default(0)
  totalAmount       Float
  currency          String      @default("USD")
  shippingAddressId String?
  shippingAddress   Address?    @relation(fields: [shippingAddressId], references: [id])
  trackingNumber    String?
  notes             String?
  country           Country     @default(US)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  items             OrderItem[]
  escrow            Escrow?
  esimProvisionings EsimProvisioning[]
  preorder          Preorder?          @relation("PreorderOrder")
  dispute           Dispute?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([orderType])
}

model OrderItem {
  id            String       @id @default(uuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId     String?
  listing       Listing?     @relation(fields: [listingId], references: [id])
  networkPlanId String?
  networkPlan   NetworkPlan? @relation(fields: [networkPlanId], references: [id])
  quantity      Int          @default(1)
  unitPrice     Float
  totalPrice    Float
  createdAt     DateTime     @default(now())

  @@index([orderId])
}

// ─── ESCROW ─────────────────────────────────────────────────────────────────

model Escrow {
  id              String       @id @default(uuid())
  orderId         String       @unique
  order           Order        @relation(fields: [orderId], references: [id])
  buyerId         String
  buyer           User         @relation("EscrowBuyer", fields: [buyerId], references: [id])
  sellerId        String
  seller          User         @relation("EscrowSeller", fields: [sellerId], references: [id])
  amount          Float
  status          EscrowStatus @default(HOLDING)
  stripePaymentId String? // Stripe PaymentIntent ID
  imeiVerified    Boolean      @default(false)
  simActivated    Boolean      @default(false)
  releasedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  dispute Dispute?

  @@index([status])
}

// ─── PREORDER ENGINE ────────────────────────────────────────────────────────

model PreorderCampaign {
  id                String    @id @default(uuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  title             String // "iPhone 18 Pro — Launch Day Preorder"
  description       String?
  depositAmount     Float // Required deposit to hold queue position
  estimatedShipDate DateTime?
  maxSlots          Int? // null = unlimited
  slotsFilled       Int       @default(0)
  isActive          Boolean   @default(true)
  country           Country   @default(US)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  preorders Preorder[]

  @@index([productId])
  @@index([isActive])
}

model Preorder {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  campaignId       String
  campaign         PreorderCampaign @relation(fields: [campaignId], references: [id])
  queuePosition    Int
  status           PreorderStatus   @default(QUEUE_OPEN)
  depositPaid      Float            @default(0)
  stripeDepositId  String? // Stripe PaymentIntent for deposit
  convertedOrderId String?          @unique
  convertedOrder   Order?           @relation("PreorderOrder", fields: [convertedOrderId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tradeIn TradeIn? @relation("PreorderTradeIn")

  @@index([userId])
  @@index([campaignId])
  @@index([status])
}

// ─── TRADE-IN (Lock-in value before launch) ─────────────────────────────────

model TradeIn {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  productId       String
  product         Product          @relation(fields: [productId], references: [id])
  deviceCondition ProductCondition
  imei            String?
  quotedValue     Float // Locked-in trade-in value
  finalValue      Float? // After inspection
  status          TradeInStatus    @default(QUOTE_GIVEN)
  preorderId      String?          @unique
  preorder        Preorder?        @relation("PreorderTradeIn", fields: [preorderId], references: [id])
  lockedUntil     DateTime? // How long the quote is valid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── AI CHATBOT ─────────────────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(uuid())
  userId    String? // null = anonymous visitor
  user      User?    @relation(fields: [userId], references: [id])
  title     String? // Auto-generated from first message
  context   Json? // { intent: "cross-border-plan", filters: {...} }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String
  metadata  Json? // { suggestedProducts: [...], suggestedPlans: [...] }
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// ─── REVIEWS & RATINGS ──────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId  String // The user being reviewed (seller)
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  orderId   String? // Optional link to the order
  rating    Int // 1-5
  title     String?
  comment   String?
  createdAt DateTime @default(now())

  @@index([authorId])
  @@index([targetId])
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "order_update", "preorder_ready", "trade_in_approved", "chat_reply", etc.
  title     String
  body      String?
  link      String? // Deep link to relevant page
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ─── PLATFORM COMMISSION & ANALYTICS ────────────────────────────────────────

model PlatformCommission {
  id               String   @id @default(uuid())
  orderId          String
  commissionPct    Float // e.g. 5.0 for 5%
  commissionAmount Float
  bountyFee        Float    @default(0) // Recurring fee from network providers
  currency         String   @default("USD")
  createdAt        DateTime @default(now())

  @@index([orderId])
}

// ─── DASHBOARD ANALYTICS (materialized/cached) ─────────────────────────────

model DashboardStats {
  id             String   @id @default(uuid())
  userId         String
  role           UserRole
  period         String // "daily", "weekly", "monthly"
  periodStart    DateTime
  totalRevenue   Float    @default(0)
  totalOrders    Int      @default(0)
  totalPreorders Int      @default(0)
  activeListings Int      @default(0)
  avgRating      Float    @default(0)
  topProducts    Json? // [{ productId, name, count }]
  computedAt     DateTime @default(now())

  @@unique([userId, period, periodStart])
  @@index([userId])
  @@index([role])
}

// ─── KYC VERIFICATION ───────────────────────────────────────────────────────

model KycDocument {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType KycDocumentType
  documentUrl  String
  status       VerificationStatus @default(PENDING)
  notes        String?
  uploadedAt   DateTime           @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?

  @@index([userId])
  @@index([status])
}

// ─── DISPUTE ENGINE ─────────────────────────────────────────────────────────

model Dispute {
  id          String        @id @default(uuid())
  orderId     String?       @unique
  order       Order?        @relation(fields: [orderId], references: [id])
  escrowId    String?       @unique
  escrow      Escrow?       @relation(fields: [escrowId], references: [id])
  raisedById  String
  raisedBy    User          @relation("DisputeRaiser", fields: [raisedById], references: [id])
  defendingId String
  defending   User          @relation("DisputeDefender", fields: [defendingId], references: [id])
  status      DisputeStatus @default(OPEN)
  reason      DisputeReason
  description String
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages DisputeMessage[]

  @@index([raisedById])
  @@index([status])
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  content     String
  evidenceUrl String?
  isAdminMsg  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([disputeId])
}

// ─── CMS & PLATFORM CONFIG ──────────────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model TrackingConfig {
  id         String   @id @default(uuid())
  provider   String   @unique // "GOOGLE_ANALYTICS" or "MATOMO"
  trackingId String
  isActive   Boolean  @default(true)
  metadata   Json?
  updatedAt  DateTime @updatedAt
}

// ─── CMS: BANNER SLIDES ─────────────────────────────────────────────────────

model BannerSlide {
  id         String   @id @default(uuid())
  title      String
  subtitle   String?
  ctaText    String?
  ctaLink    String?
  desktopImg String
  mobileImg  String?
  gradient   String?  // CSS gradient overlay class
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
}

// ─── CMS: HOMEPAGE SECTIONS ─────────────────────────────────────────────────

model HomepageSection {
  id         String   @id @default(uuid())
  sectionKey String   @unique // "stats_bar", "features", "how_it_works", "trust_signals", "cta"
  title      String?
  subtitle   String?
  content    Json     // Array of section-specific items
  isVisible  Boolean  @default(true)
  sortOrder  Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@index([sectionKey])
}

// ─── CMS: FOOTER ─────────────────────────────────────────────────────────────

model FooterColumn {
  id        String       @id @default(uuid())
  heading   String
  sortOrder Int          @default(0)
  isVisible Boolean      @default(true)
  links     FooterLink[]
  updatedAt DateTime     @updatedAt
}

model FooterLink {
  id        String       @id @default(uuid())
  columnId  String
  column    FooterColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  label     String
  href      String
  sortOrder Int          @default(0)
  isVisible Boolean      @default(true)

  @@index([columnId])
}

// ─── CMS: SEO METADATA ──────────────────────────────────────────────────────

model SeoMeta {
  id              String   @id @default(uuid())
  pagePath        String   @unique // "/", "/about", "/preorder"
  title           String
  description     String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  robotsDirective String?  // "index,follow", "noindex"
  structuredData  Json?    // JSON-LD schema.org data
  updatedAt       DateTime @updatedAt

  @@index([pagePath])
}

// ─── ADMIN: DELETION QUEUE ──────────────────────────────────────────────────

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model DeletionRequest {
  id           String                @id @default(uuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       String?
  status       DeletionRequestStatus @default(PENDING)
  adminNotes   String?
  processedAt  DateTime?
  processedBy  String?               // Admin user ID
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId])
  @@index([status])
}

